---
import { RELEASES_URL, REPO_URL } from "../lib/github";
import DownloadIcon from "./icons/DownloadIcon.astro";
import StarIcon from "./icons/StarIcon.astro";

interface Props {
  stars: number | null;
}

const { stars } = Astro.props;

const links = [
  { href: "#how-it-works", label: "How it works" },
  { href: "#features", label: "Features" },
  { href: "#engines", label: "Engines" },
  { href: "#install", label: "Install" },
];
---

<header class="nav">
  <div class="container nav-inner">
    <a href="#top" class="nav-brand">based</a>

    <nav class="nav-links" aria-label="Primary">
      {links.map((link) => <a href={link.href}>{link.label}</a>)}
    </nav>

    <div class="nav-actions">
      <a
        href={REPO_URL}
        class="btn btn-secondary nav-btn nav-star"
        target="_blank"
        rel="noopener noreferrer"
      >
        <StarIcon class="btn-icon" />
        <span class="nav-star-label">Star</span>
        {stars !== null && (
          <span class="btn-count" aria-label={stars === -1 ? "rate limited" : `${stars.toLocaleString()} stars`}>
            {stars === -1 ? "?" : stars.toLocaleString()}
          </span>
        )}
      </a>
      <a href={RELEASES_URL} class="btn btn-primary nav-btn" target="_blank" rel="noopener noreferrer">
        <DownloadIcon class="btn-icon" />
        Download
      </a>
    </div>
  </div>
</header>

<style>
  .nav {
    position: sticky;
    top: 0;
    z-index: 50;
    border-bottom: 1px solid transparent;
    background: color-mix(in srgb, var(--bg) 72%, transparent);
    backdrop-filter: blur(14px) saturate(140%);
    transition: border-color 200ms var(--motion-ease);
  }

  :global(body.scrolled) .nav {
    border-bottom-color: var(--border);
  }

  .nav-inner {
    display: flex;
    align-items: center;
    gap: 1.5rem;
    height: 3.75rem;
  }

  .nav-brand {
    font-size: 1.35rem;
    font-weight: 700;
    letter-spacing: -0.04em;
    flex-shrink: 0;
  }

  .nav-links {
    display: flex;
    align-items: center;
    gap: 1.6rem;
    margin-inline: auto;
    color: var(--muted);
    font-size: 0.92rem;
  }

  .nav-links a {
    transition: color 120ms var(--motion-ease);
  }

  .nav-links a:hover {
    color: var(--text);
  }

  .nav-actions {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    flex-shrink: 0;
  }

  .nav-btn {
    padding: 0.55rem 0.95rem;
    font-size: 0.9rem;
  }

  @media (max-width: 860px) {
    .nav-links {
      display: none;
    }
  }

  @media (max-width: 540px) {
    .nav-star-label,
    .nav-star .btn-count {
      display: none;
    }

    .nav-star {
      padding-inline: 0.7rem;
    }
  }
</style>
