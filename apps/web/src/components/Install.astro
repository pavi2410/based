---
import { findAssetUrl, RELEASES_URL, type LatestRelease } from "../lib/github";
import Reveal from "./Reveal.astro";

interface Props {
  release: LatestRelease | null;
}

const { release } = Astro.props;

const version = release?.tag_name ?? null;

// Direct download URLs — fall back to Releases page if asset not found
const macUrl      = findAssetUrl(release, /aarch64\.dmg$/i)          ?? RELEASES_URL;
const linuxDebUrl = findAssetUrl(release, /\.deb$/i)                  ?? RELEASES_URL;
const linuxAppUrl = findAssetUrl(release, /\.AppImage$/i);
const windowsUrl  = findAssetUrl(release, /x64-setup\.exe$/i, /\.exe$/i) ?? RELEASES_URL;

const platforms = [
  {
    os:        "mac",
    name:      "macOS",
    detail:    "Apple Silicon",
    primary:   { label: ".dmg installer", url: macUrl },
    secondary: null,
    iconSrc:   "https://cdn.simpleicons.org/apple/ffffff",
    iconAlt:   "Apple",
  },
  {
    os:        "linux",
    name:      "Linux",
    detail:    "x86-64",
    primary:   { label: ".deb (Debian / Ubuntu)", url: linuxDebUrl },
    secondary: linuxAppUrl ? { label: ".AppImage (universal)", url: linuxAppUrl } : null,
    iconSrc:   "https://cdn.simpleicons.org/linux/ffffff",
    iconAlt:   "Linux",
  },
  {
    os:        "windows",
    name:      "Windows",
    detail:    "Windows 10 & 11",
    primary:   { label: ".exe installer", url: windowsUrl },
    secondary: null,
    iconSrc:   "https://cdn.simpleicons.org/windows/ffffff",
    iconAlt:   "Windows",
  },
];
---

<section class="section install" id="install">
  <div class="section-head">
    <span class="eyebrow">Install</span>
    <h2 class="section-title">
      Download based{version ? <span class="install-version mono">&nbsp;{version}</span> : ""}.
    </h2>
    <p class="section-lead">
      Grab the latest stable release for your platform. Free and open source —
      no sign-up required.
    </p>
  </div>

  <div class="install-grid">
    {
      platforms.map((platform, index) => (
        <Reveal delay={index % 3}>
          <div class="card install-card" data-os={platform.os}>
            <span class="install-rec mono">Detected</span>

            <span class="install-icon">
              <img
                src={platform.iconSrc}
                alt={platform.iconAlt}
                width="20"
                height="20"
                loading="eager"
                decoding="async"
              />
            </span>

            <h3 class="card-title">{platform.name}</h3>
            <p class="install-detail">{platform.detail}</p>

            <div class="install-links">
              <a
                href={platform.primary.url}
                class="install-dl-link"
                download
                target="_blank"
                rel="noopener noreferrer"
              >
                <svg width="13" height="13" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true">
                  <path d="M7.25 1.75a.75.75 0 0 1 1.5 0v6.69l2.22-2.22a.75.75 0 1 1 1.06 1.06l-3.5 3.5a.75.75 0 0 1-1.06 0l-3.5-3.5a.75.75 0 0 1 1.06-1.06l2.22 2.22V1.75ZM2.75 11a.75.75 0 0 1 .75.75v1.75a.25.25 0 0 0 .25.25h8.5a.25.25 0 0 0 .25-.25v-1.75a.75.75 0 0 1 1.5 0v1.75A1.75 1.75 0 0 1 12.25 15h-8.5A1.75 1.75 0 0 1 2 13.5v-1.75A.75.75 0 0 1 2.75 11Z"/>
                </svg>
                {platform.primary.label}
              </a>
              {platform.secondary && (
                <a
                  href={platform.secondary.url}
                  class="install-dl-link install-dl-link--secondary"
                  download
                  target="_blank"
                  rel="noopener noreferrer"
                >
                  <svg width="13" height="13" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true">
                    <path d="M7.25 1.75a.75.75 0 0 1 1.5 0v6.69l2.22-2.22a.75.75 0 1 1 1.06 1.06l-3.5 3.5a.75.75 0 0 1-1.06 0l-3.5-3.5a.75.75 0 0 1 1.06-1.06l2.22 2.22V1.75ZM2.75 11a.75.75 0 0 1 .75.75v1.75a.25.25 0 0 0 .25.25h8.5a.25.25 0 0 0 .25-.25v-1.75a.75.75 0 0 1 1.5 0v1.75A1.75 1.75 0 0 1 12.25 15h-8.5A1.75 1.75 0 0 1 2 13.5v-1.75A.75.75 0 0 1 2.75 11Z"/>
                  </svg>
                  {platform.secondary.label}
                </a>
              )}
            </div>
          </div>
        </Reveal>
      ))
    }
  </div>

  <Reveal class="install-note-wrap">
    <p class="install-note">
      Installers are currently <strong>unsigned</strong>. On macOS, open
      <span class="mono">System Settings → Privacy &amp; Security → Open Anyway</span>;
      on Windows, choose <span class="mono">More info → Run anyway</span>. Each release
      ships a <span class="mono">checksums.txt</span> with SHA-256 hashes.
      <a href={RELEASES_URL} target="_blank" rel="noopener noreferrer" class="releases-link">
        Browse all releases →
      </a>
    </p>
  </Reveal>
</section>

<script>
  const ua = (navigator.userAgent + " " + (navigator.platform ?? "")).toLowerCase();
  let os: string | null = null;
  if (ua.includes("mac")) os = "mac";
  else if (ua.includes("win")) os = "windows";
  else if (ua.includes("linux")) os = "linux";

  if (os) {
    document.querySelector(`.install-card[data-os="${os}"]`)?.classList.add("is-detected");
  }
</script>

<style>
  .install-version {
    font-size: 0.75em;
    font-weight: 500;
    color: var(--muted);
    letter-spacing: 0.02em;
    vertical-align: middle;
  }

  .install-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1rem;
  }

  .install-card {
    position: relative;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 0;
  }

  .install-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2.75rem;
    height: 2.75rem;
    border-radius: 10px;
    background: color-mix(in srgb, var(--text) 10%, transparent);
    border: 1px solid color-mix(in srgb, var(--text) 14%, transparent);
    margin-bottom: 1rem;
  }

  .install-icon img {
    width: 20px;
    height: 20px;
    object-fit: contain;
  }

  .install-detail {
    margin: 0.3rem 0 0;
    color: var(--muted);
    font-size: 0.88rem;
  }

  .install-links {
    margin-top: 1.1rem;
    display: flex;
    flex-direction: column;
    gap: 0.45rem;
    width: 100%;
  }

  .install-dl-link {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-size: 0.85rem;
    font-family: var(--font-mono);
    color: var(--accent-blue);
    transition: color 120ms var(--motion-ease), gap 120ms var(--motion-ease);
  }

  .install-dl-link:hover {
    color: var(--text);
    gap: 0.6rem;
  }

  .install-dl-link--secondary {
    color: var(--muted);
    font-size: 0.8rem;
  }

  .install-dl-link--secondary:hover {
    color: var(--text);
  }

  .install-rec {
    position: absolute;
    top: 1rem;
    right: 1rem;
    display: none;
    padding: 0.15rem 0.5rem;
    border-radius: 999px;
    font-size: 0.68rem;
    letter-spacing: 0.04em;
    color: var(--mongo);
    background: color-mix(in srgb, var(--mongo) 14%, transparent);
  }

  .install-card.is-detected {
    border-color: color-mix(in srgb, var(--mongo) 45%, var(--border));
    box-shadow: 0 0 0 1px color-mix(in srgb, var(--mongo) 20%, transparent);
  }

  .install-card.is-detected .install-rec {
    display: inline-block;
  }

  :global(.install-note-wrap) {
    margin-top: 1.5rem;
  }

  .install-note {
    margin: 0;
    max-width: 70ch;
    color: var(--muted);
    font-size: 0.88rem;
    line-height: 1.6;
  }

  .install-note strong {
    color: var(--text);
    font-weight: 600;
  }

  .releases-link {
    margin-left: 0.25rem;
    color: var(--accent-blue);
    text-decoration: underline;
    text-underline-offset: 3px;
    text-decoration-color: color-mix(in srgb, var(--accent-blue) 40%, transparent);
  }

  .releases-link:hover {
    color: var(--text);
  }

  @media (max-width: 860px) {
    .install-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
