---
interface Props { size?: number; class?: string; }
const { size = 18, class: cls = "" } = Astro.props;
---
<svg
  width={size}
  height={size}
  viewBox="0 0 24 24"
  fill="none"
  stroke="currentColor"
  stroke-width="2"
  stroke-linecap="round"
  stroke-linejoin="round"
  class={cls}
  aria-hidden="true"
  xmlns="http://www.w3.org/2000/svg"
>
  <path d="M6 9l6 6 6-6"/>
</svg>
