---
import { REPO_URL } from "../lib/github";
import DownloadIcon from "./icons/DownloadIcon.astro";
import StarIcon from "./icons/StarIcon.astro";
import HeroConstellation from "./HeroConstellation.astro";

interface Props {
  stars: number | null;
  version: string | null;
}

const { stars, version } = Astro.props;
---

<section class="hero" id="top">
  <HeroConstellation />

  <div class="hero-copy">
  <p class="eyebrow intro">Local-first database client</p>
  <h1 class="hero-wordmark intro intro-delay-1">based</h1>
  <p class="hero-headline intro intro-delay-2">
    The database client your whole team can commit to git.
  </p>
  <p class="hero-subline intro intro-delay-3">
    Version-controlled connections and queries. Native Rust and GPUI. Postgres,
    SQLite, and MongoDB — no accounts, no backend.
  </p>

  {version && <p class="hero-version mono intro intro-delay-4">{version}</p>}

  <div class="cta-row hero-cta-row intro intro-delay-4">
    <a href="#install" class="btn btn-primary">
      <DownloadIcon class="btn-icon" />
      <span>Download for free</span>
    </a>
    <a href={REPO_URL} class="btn btn-secondary" target="_blank" rel="noopener noreferrer">
      <StarIcon class="btn-icon" />
      <span>Star on GitHub</span>
      {
        stars !== null && (
          <span class="btn-count" aria-label={stars === -1 ? "rate limited" : `${stars.toLocaleString()} stars`}>
            {stars === -1 ? "?" : stars.toLocaleString()}
          </span>
        )
      }
    </a>
  </div>
  </div>
</section>

<style>
  .hero {
    position: relative;
    padding-top: clamp(3.5rem, 12vh, 6rem);
  }

  .hero-copy {
    position: relative;
    z-index: 1;
    max-width: 52rem;
  }

  .hero-wordmark {
    font-size: clamp(3rem, 9vw, 5rem);
    font-weight: 700;
    letter-spacing: -0.05em;
    line-height: 1;
    margin: 0;
  }

  .hero-headline {
    margin: 1.4rem 0 0;
    max-width: 24ch;
    font-size: clamp(1.6rem, 4.5vw, 2.75rem);
    font-weight: 600;
    letter-spacing: -0.03em;
    line-height: 1.12;
  }

  .hero-subline {
    margin: 1rem 0 0;
    max-width: 50ch;
    color: var(--muted);
    font-size: clamp(1rem, 2vw, 1.2rem);
    line-height: 1.6;
  }

  .hero-version {
    margin: 1.75rem 0 0;
    font-size: 0.8rem;
    letter-spacing: 0.04em;
    color: color-mix(in srgb, var(--muted) 80%, transparent);
  }

  .hero-cta-row {
    margin-top: 0.85rem;
  }
</style>
