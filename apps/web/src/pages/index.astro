---
import AmbientGlow from "../components/AmbientGlow.astro";
import Engines from "../components/Engines.astro";
import Faq from "../components/Faq.astro";
import Features from "../components/Features.astro";
import Footer from "../components/Footer.astro";
import Hero from "../components/Hero.astro";
import HowItWorks from "../components/HowItWorks.astro";
import Install from "../components/Install.astro";
import LocalFirst from "../components/LocalFirst.astro";
import Support from "../components/Support.astro";
import Nav from "../components/Nav.astro";
import Problem from "../components/Problem.astro";
import Screenshot from "../components/Screenshot.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
import { fetchAllReleases, fetchLatestRelease, fetchStarCount, RATE_LIMITED, sumAllDownloads } from "../lib/github";

const [stars, release, allReleases] = await Promise.all([
  fetchStarCount(),
  fetchLatestRelease(),
  import.meta.env.DEV ? fetchAllReleases() : Promise.resolve(null),
]);

const totalDownloads =
  allReleases === "rate_limited" ? RATE_LIMITED
  : allReleases ? sumAllDownloads(allReleases)
  : null;
---

<BaseLayout>
  <div class="page">
    <AmbientGlow />
    <Nav stars={stars} />
    <main class="container content">
      <Hero stars={stars} version={release?.tag_name ?? null} />
      <Screenshot />
      <Problem />
      <HowItWorks />
      <Features />
      <Engines />
      <LocalFirst />
      <Install release={release} allReleases={allReleases} totalDownloads={totalDownloads} />
      <Support />
      <Faq />
      <Footer />
    </main>
  </div>
</BaseLayout>

<style>
  .content {
    position: relative;
    z-index: 1;
  }
</style>
