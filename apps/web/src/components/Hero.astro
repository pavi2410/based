---
import { RELEASES_URL, REPO_URL } from "../lib/github";

interface Props {
  stars: number | null;
  version: string | null;
}

const { stars, version } = Astro.props;
---

<section class="hero" id="top">
  <p class="eyebrow intro">Local-first database client</p>
  <h1 class="hero-wordmark intro intro-delay-1">based</h1>
  <p class="hero-headline intro intro-delay-2">
    The database client your whole team can commit to git.
  </p>
  <p class="hero-subline intro intro-delay-3">
    Version-controlled connections and queries. Native Rust and GPUI. Postgres,
    SQLite, and MongoDB — no accounts, no backend.
  </p>

  {version && <p class="hero-version mono intro intro-delay-4">{version}</p>}

  <div class="cta-row hero-cta-row intro intro-delay-4">
    <a href={RELEASES_URL} class="btn btn-primary" target="_blank" rel="noopener noreferrer">
      <svg
        class="btn-icon"
        width="16"
        height="16"
        viewBox="0 0 16 16"
        fill="currentColor"
        aria-hidden="true"
      >
        <path
          d="M7.25 1.75a.75.75 0 0 1 1.5 0v6.69l2.22-2.22a.75.75 0 1 1 1.06 1.06l-3.5 3.5a.75.75 0 0 1-1.06 0l-3.5-3.5a.75.75 0 0 1 1.06-1.06l2.22 2.22V1.75ZM2.75 11a.75.75 0 0 1 .75.75v1.75a.25.25 0 0 0 .25.25h8.5a.25.25 0 0 0 .25-.25v-1.75a.75.75 0 0 1 1.5 0v1.75A1.75 1.75 0 0 1 12.25 15h-8.5A1.75 1.75 0 0 1 2 13.5v-1.75A.75.75 0 0 1 2.75 11Z"
        ></path>
      </svg>
      <span>Download for free</span>
    </a>
    <a href={REPO_URL} class="btn btn-secondary" target="_blank" rel="noopener noreferrer">
      <svg
        class="btn-icon"
        width="16"
        height="16"
        viewBox="0 0 16 16"
        fill="currentColor"
        aria-hidden="true"
      >
        <path
          d="M8 .25a.75.75 0 0 1 .673.418l1.882 3.815 4.21.612a.75.75 0 0 1 .416 1.279l-3.046 2.97.719 4.192a.75.75 0 0 1-1.088.791L8 12.347l-3.766 1.98a.75.75 0 0 1-1.088-.79l.72-4.194L.818 6.374a.75.75 0 0 1 .416-1.28l4.21-.611L7.327.668A.75.75 0 0 1 8 .25Z"
        ></path>
      </svg>
      <span>Star on GitHub</span>
      {
        stars !== null && (
          <span class="btn-count" aria-label={`${stars.toLocaleString()} stars`}>
            {stars.toLocaleString()}
          </span>
        )
      }
    </a>
  </div>
</section>

<style>
  .hero {
    padding-top: clamp(3.5rem, 12vh, 6rem);
    max-width: 52rem;
  }

  .hero-wordmark {
    font-size: clamp(3rem, 9vw, 5rem);
    font-weight: 700;
    letter-spacing: -0.05em;
    line-height: 1;
    margin: 0;
  }

  .hero-headline {
    margin: 1.4rem 0 0;
    max-width: 24ch;
    font-size: clamp(1.6rem, 4.5vw, 2.75rem);
    font-weight: 600;
    letter-spacing: -0.03em;
    line-height: 1.12;
  }

  .hero-subline {
    margin: 1rem 0 0;
    max-width: 50ch;
    color: var(--muted);
    font-size: clamp(1rem, 2vw, 1.2rem);
    line-height: 1.6;
  }

  .hero-version {
    margin: 1.75rem 0 0;
    font-size: 0.8rem;
    letter-spacing: 0.04em;
    color: color-mix(in srgb, var(--muted) 80%, transparent);
  }

  .hero-cta-row {
    margin-top: 0.85rem;
  }
</style>
