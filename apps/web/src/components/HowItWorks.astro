---
import { Code } from "astro:components";
import Reveal from "./Reveal.astro";

const connectionToml = `schema_version = 1
label = "Local PostgreSQL (Docker)"
engine = "postgres"
tags = ["local", "dev"]

host = "localhost"
port = 5432
database = "based"
username = "based"
password = { env = "LOCAL_PG_PASSWORD" }
ssl = false`;

const queryToml = `schema_version = 1

name = "Churn by Geography"
description = "Customer exit rate by country"
tags = ["churn", "reports"]

[target]
connection = "public/mindsdb"

[sql]
query = """
SELECT
    Geography,
    COUNT(*) AS customers,
    SUM(CASE WHEN Exited = 1 THEN 1 ELSE 0 END) AS exited
FROM demo.customer_churn
GROUP BY Geography
ORDER BY customers DESC;
"""`;

const envExample = `# Copy to .env and fill in values for local connections.

# Local PostgreSQL (docker compose — default password is "based")
LOCAL_PG_PASSWORD=based

# Local MongoDB (docker compose)
MONGO_URL=mongodb://localhost:27017`;

const tabs = [
  { id: "conn", file: "connections/local.conn.toml", code: connectionToml, lang: "toml" as const },
  { id: "query", file: "queries/churn.query.toml", code: queryToml, lang: "toml" as const },
  { id: "env", file: ".env.example", code: envExample, lang: "bash" as const },
];

const theme = "github-dark-default";
---

<section class="section how" id="how-it-works">
  <div class="section-head">
    <span class="eyebrow">How it works</span>
    <h2 class="section-title">One folder. Plain files. Committed to git.</h2>
    <p class="section-lead">
      based reads a <span class="mono">.based/</span> directory in your repo. Connections
      and saved queries are small TOML files your team reviews in pull requests. Secrets
      go in a gitignored <span class="mono">.env</span> — never committed.
    </p>
  </div>

  <div class="how-grid">
    <Reveal class="how-tree-wrap">
      <div class="how-tree" aria-label="Example .based directory">
        <div class="tree-head mono">.based/</div>
        <ul class="tree">
          <li><span class="tree-file">project.toml</span><span class="tag tag-git">committed</span></li>
          <li class="tree-dir">connections/</li>
          <li class="tree-indent"><span class="tree-file">local.conn.toml</span><span class="tag tag-git">committed</span></li>
          <li class="tree-dir">queries/</li>
          <li class="tree-indent"><span class="tree-file">churn.query.toml</span><span class="tag tag-git">committed</span></li>
          <li><span class="tree-file">.env.example</span><span class="tag tag-git">committed</span></li>
          <li><span class="tree-file tree-muted">.env</span><span class="tag tag-secret">gitignored</span></li>
          <li><span class="tree-file tree-muted">state/</span><span class="tag tag-secret">gitignored</span></li>
        </ul>
      </div>
    </Reveal>

    <Reveal delay={1} class="how-code-wrap">
      <div class="how-code">
        <div class="tabs" role="tablist">
          {
            tabs.map((tab, index) => (
              <Fragment>
                <input
                  type="radio"
                  name="how-tab"
                  id={`how-${tab.id}`}
                  class="tab-radio"
                  checked={index === 0}
                />
                <label for={`how-${tab.id}`} class="tab-label mono">
                  {tab.file}
                </label>
              </Fragment>
            ))
          }
        </div>
        <div class="panels">
          {
            tabs.map((tab) => (
              <div class={`panel panel-${tab.id}`}>
                <Code code={tab.code} lang={tab.lang} theme={theme} />
              </div>
            ))
          }
        </div>
      </div>
    </Reveal>
  </div>
</section>

<style>
  .how-grid {
    display: grid;
    grid-template-columns: minmax(0, 0.85fr) minmax(0, 1.6fr);
    gap: 1.25rem;
    align-items: start;
  }

  .how-tree {
    padding: 1.25rem 1.4rem;
    border: 1px solid var(--border);
    border-radius: 14px;
    background: color-mix(in srgb, var(--surface) 86%, transparent);
    font-family: var(--font-mono);
    font-size: 0.85rem;
  }

  .tree-head {
    color: var(--sqlite);
    margin-bottom: 0.7rem;
    font-weight: 500;
  }

  .tree {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }

  .tree li {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.5rem;
    color: var(--text);
  }

  .tree-dir {
    color: var(--muted);
  }

  .tree-indent {
    padding-left: 1rem;
  }

  .tree-muted .tree-file,
  .tree-file.tree-muted {
    color: var(--muted);
  }

  .tag {
    font-size: 0.68rem;
    letter-spacing: 0.03em;
    padding: 0.12rem 0.4rem;
    border-radius: 5px;
    white-space: nowrap;
  }

  .tag-git {
    color: var(--mongo);
    background: color-mix(in srgb, var(--mongo) 14%, transparent);
  }

  .tag-secret {
    color: #d98c5f;
    background: color-mix(in srgb, #d98c5f 14%, transparent);
  }

  .how-code {
    border: 1px solid var(--border);
    border-radius: 14px;
    overflow: hidden;
    background: var(--surface);
  }

  .tabs {
    display: flex;
    flex-wrap: wrap;
    border-bottom: 1px solid var(--border);
    background: color-mix(in srgb, var(--bg) 50%, var(--surface));
  }

  .tab-radio {
    position: absolute;
    opacity: 0;
    pointer-events: none;
  }

  .tab-label {
    padding: 0.7rem 1rem;
    font-size: 0.8rem;
    color: var(--muted);
    cursor: pointer;
    border-bottom: 2px solid transparent;
    transition:
      color 120ms var(--motion-ease),
      border-color 120ms var(--motion-ease),
      background 120ms var(--motion-ease);
  }

  .tab-label:hover {
    color: var(--text);
  }

  .panel {
    display: none;
  }

  .panel :global(pre) {
    margin: 0;
    padding: 1.25rem 1.4rem;
    background: var(--surface) !important;
    font-size: 0.84rem;
    line-height: 1.6;
    overflow-x: auto;
  }

  /* CSS-only tab switching: each radio toggles its matching label + panel */
  .tab-radio:checked + .tab-label {
    color: var(--text);
    border-bottom-color: var(--accent-blue);
    background: color-mix(in srgb, var(--accent-blue) 8%, transparent);
  }

  .tabs:has(#how-conn:checked) ~ .panels .panel-conn,
  .tabs:has(#how-query:checked) ~ .panels .panel-query,
  .tabs:has(#how-env:checked) ~ .panels .panel-env {
    display: block;
  }

  @media (max-width: 860px) {
    .how-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
