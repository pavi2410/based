---
import FileBrowser from "./FileBrowser.astro";
---

<section class="section how" id="how-it-works">
  <div class="section-head">
    <span class="eyebrow">How it works</span>
    <h2 class="section-title">One folder. Plain files. Committed to git.</h2>
    <p class="section-lead">
      based reads a <span class="mono">.based/</span> directory in your repo.
      Connections and saved queries are small TOML files your team reviews in
      pull requests. Secrets go in a gitignored <span class="mono">.env</span> —
      never committed.
    </p>
  </div>

  <FileBrowser />
</section>
