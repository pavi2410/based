---
import { Code } from "astro:components";
import FileIcon from "./icons/FileIcon.astro";
import FolderIcon from "./icons/FolderIcon.astro";
import projectToml from "../assets/filebrowser/project.toml?raw";
import queryToml from "../assets/filebrowser/churn.query.toml?raw";
import connectionToml from "../assets/filebrowser/local.conn.toml?raw";
import envExample from "../assets/filebrowser/.env.example?raw";

const theme = "github-dark-default";
---

<!--
  The outer .fb div is both the reveal target and the CSS state-machine root.
  Radio inputs and .fb-card are siblings inside it, sharing the same Astro CID,
  so the scoped `#fb-query:checked ~ .fb-card` selectors work correctly.
-->
<div class="fb" data-reveal data-reveal-stagger="0">
  <input type="radio" name="fb-file" id="fb-query" class="fb-radio" checked />
  <input type="radio" name="fb-file" id="fb-conn"  class="fb-radio" />
  <input type="radio" name="fb-file" id="fb-env"   class="fb-radio" />
  <input type="radio" name="fb-file" id="fb-proj"  class="fb-radio" />

  <div class="fb-card">
    <header class="fb-pane-header fb-header-tree mono" aria-hidden="true">
      <FolderIcon class="fb-icon fb-icon-folder" />
      .based/
    </header>

    <div class="fb-divider" aria-hidden="true"></div>

    <header class="fb-pane-header fb-header-editor mono">
      <FileIcon class="fb-icon" />
      <span class="fn fn-proj">project.toml</span>
      <span class="fn fn-query">queries/churn.query.toml</span>
      <span class="fn fn-conn">connections/local.conn.toml</span>
      <span class="fn fn-env">.env.example</span>
    </header>

    <!-- ── Left: file tree ──────────────────────────────────── -->
    <nav class="fb-tree" aria-label=".based/ directory">
      <ul class="fb-list">
        <li class="fb-item" data-file="proj">
          <label for="fb-proj" class="fb-node fb-selectable">
            <FileIcon class="fb-icon" />
            project.toml
          </label>
          <span class="tag tag-git">committed</span>
        </li>

        <li class="fb-item">
          <span class="fb-node fb-dir">
            <FolderIcon class="fb-icon fb-icon-folder" />
            connections/
          </span>
        </li>
        <li class="fb-item fb-child" data-file="conn">
          <label for="fb-conn" class="fb-node fb-selectable">
            <FileIcon class="fb-icon" />
            local.conn.toml
          </label>
          <span class="tag tag-git">committed</span>
        </li>

        <li class="fb-item">
          <span class="fb-node fb-dir">
            <FolderIcon class="fb-icon fb-icon-folder" />
            queries/
          </span>
        </li>
        <li class="fb-item fb-child" data-file="query">
          <label for="fb-query" class="fb-node fb-selectable">
            <FileIcon class="fb-icon" />
            churn.query.toml
          </label>
          <span class="tag tag-git">committed</span>
        </li>

        <li class="fb-item" data-file="env">
          <label for="fb-env" class="fb-node fb-selectable">
            <FileIcon class="fb-icon" />
            .env.example
          </label>
          <span class="tag tag-git">committed</span>
        </li>

        <li class="fb-item">
          <span class="fb-node fb-muted">
            <FileIcon class="fb-icon" />
            .env
          </span>
          <span class="tag tag-secret">gitignored</span>
        </li>

        <li class="fb-item">
          <span class="fb-node fb-muted">
            <FolderIcon class="fb-icon fb-icon-folder" />
            state/
          </span>
          <span class="tag tag-secret">gitignored</span>
        </li>
      </ul>
    </nav>

    <!-- ── Right: code viewer ───────────────────────────────── -->
    <div class="fb-editor">
      <div class="fb-panels">
        <div class="fb-panel fp-proj">
          <Code code={projectToml} lang="toml" theme={theme} />
        </div>
        <div class="fb-panel fp-query">
          <Code code={queryToml} lang="toml" theme={theme} />
        </div>
        <div class="fb-panel fp-conn">
          <Code code={connectionToml} lang="toml" theme={theme} />
        </div>
        <div class="fb-panel fp-env">
          <Code code={envExample} lang="bash" theme={theme} />
        </div>
      </div>
    </div>
  </div>
</div>

<style>
  .fb-radio {
    position: absolute;
    opacity: 0;
    pointer-events: none;
  }

  .fb-card {
    --fb-tree-width: minmax(300px, 36%);
    display: grid;
    grid-template-columns: var(--fb-tree-width) 1px minmax(0, 1fr);
    grid-template-rows: auto 1fr;
    border: 1px solid var(--border);
    border-radius: 14px;
    overflow: hidden;
    background: var(--surface);
    font-size: 0.84rem;
  }

  .fb-pane-header {
    display: flex;
    align-items: center;
    gap: 0.35rem;
    min-height: 2.25rem;
    padding: 0 0.85rem;
    border-bottom: 1px solid var(--border);
    box-sizing: border-box;
    font-size: 0.77rem;
    background: color-mix(in srgb, var(--bg) 35%, var(--surface));
  }

  .fb-header-tree {
    grid-column: 1;
    grid-row: 1;
    color: var(--sqlite);
    font-weight: 500;
    font-size: 0.82rem;
    background: color-mix(in srgb, var(--bg) 40%, var(--surface));
  }

  .fb-header-editor {
    grid-column: 3;
    grid-row: 1;
    color: var(--muted);
  }

  .fb-divider {
    grid-column: 2;
    grid-row: 1 / -1;
    background: var(--border);
  }

  /* ── Left: tree ──────────────────────────────────────────── */
  .fb-tree {
    grid-column: 1;
    grid-row: 2;
    padding: 0.35rem 0 0.75rem;
    background: color-mix(in srgb, var(--bg) 40%, var(--surface));
    overflow: hidden;
  }

  .fb-list {
    list-style: none;
    margin: 0;
    padding: 0 0.65rem;
  }

  .fb-item {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    min-height: 1.75rem;
    padding: 0 0.2rem;
  }

  .fb-child {
    margin-left: 1rem;
    position: relative;
  }

  .fb-child::before {
    content: '';
    position: absolute;
    left: -0.6rem;
    top: -0.45rem;
    bottom: 50%;
    width: 1px;
    background: color-mix(in srgb, var(--text) 15%, transparent);
  }

  .fb-child::after {
    content: '';
    position: absolute;
    left: -0.6rem;
    top: 50%;
    width: 0.45rem;
    height: 1px;
    background: color-mix(in srgb, var(--text) 15%, transparent);
  }

  .fb-node {
    display: flex;
    align-items: center;
    gap: 0.45rem;
    font-family: var(--font-mono);
    color: var(--text);
    /* don't grow — keeps hover/selection off the gap before status badges */
    flex: 0 1 auto;
    min-width: 0;
    max-width: 100%;
    padding: 0.2rem 0.5rem;
    border-radius: 5px;
    /* truncate only when the row truly runs out of space */
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .fb-selectable {
    cursor: pointer;
    color: var(--muted);
    transition: background 100ms var(--motion-ease), color 100ms var(--motion-ease);
  }

  .fb-selectable:hover {
    background: color-mix(in srgb, var(--text) 7%, transparent);
    color: var(--text);
  }

  .fb-dir  { color: var(--muted); }
  .fb-muted { color: color-mix(in srgb, var(--muted) 55%, transparent); }

  /* Icons live inside child Astro components (different CID) — must use :global() */
  :global(.fb-icon) {
    flex-shrink: 0;
    min-width: 14px; /* prevent flex from squishing below explicit width */
    opacity: 0.7;
  }
  :global(.fb-icon-folder) { color: #e8a354; opacity: 0.9; }

  .tag {
    flex-shrink: 0;
    margin-left: auto;
    font-size: 0.6rem;
    letter-spacing: 0.03em;
    padding: 0.12rem 0.38rem;
    border-radius: 4px;
    white-space: nowrap;
    font-family: var(--font-mono);
  }

  .tag-git    { color: var(--mongo); background: color-mix(in srgb, var(--mongo) 14%, transparent); }
  .tag-secret { color: #d98c5f;      background: color-mix(in srgb, #d98c5f 14%, transparent); }

  /* ── Right: editor ───────────────────────────────────────── */
  .fb-editor {
    grid-column: 3;
    grid-row: 2;
    display: flex;
    flex-direction: column;
    min-width: 0;
    overflow: hidden;
  }

  .fn { display: none; }

  .fb-panel { display: none; }

  .fb-panel :global(pre) {
    margin: 0;
    padding: 1rem 1.25rem;
    background: var(--surface) !important;
    font-size: 0.82rem;
    line-height: 1.65;
    overflow-x: auto;
  }

  /* ── CSS state machine ───────────────────────────────────── */
  #fb-proj:checked  ~ .fb-card [data-file="proj"]  .fb-selectable,
  #fb-query:checked ~ .fb-card [data-file="query"] .fb-selectable,
  #fb-conn:checked  ~ .fb-card [data-file="conn"]  .fb-selectable,
  #fb-env:checked   ~ .fb-card [data-file="env"]   .fb-selectable {
    background: color-mix(in srgb, var(--accent-blue) 14%, transparent);
    color: var(--text);
  }

  #fb-proj:checked  ~ .fb-card .fn-proj,
  #fb-query:checked ~ .fb-card .fn-query,
  #fb-conn:checked  ~ .fb-card .fn-conn,
  #fb-env:checked   ~ .fb-card .fn-env { display: inline; }

  #fb-proj:checked  ~ .fb-card .fp-proj,
  #fb-query:checked ~ .fb-card .fp-query,
  #fb-conn:checked  ~ .fb-card .fp-conn,
  #fb-env:checked   ~ .fb-card .fp-env { display: block; }

  /* ── Responsive ──────────────────────────────────────────── */
  @media (max-width: 860px) {
    .fb-card {
      grid-template-columns: 1fr;
      grid-template-rows: auto auto 1px auto auto;
    }

    .fb-header-tree { grid-column: 1; grid-row: 1; }
    .fb-tree { grid-column: 1; grid-row: 2; }
    .fb-divider {
      grid-column: 1;
      grid-row: 3;
      width: 100%;
      height: 1px;
    }
    .fb-header-editor { grid-column: 1; grid-row: 4; }
    .fb-editor { grid-column: 1; grid-row: 5; }
  }
</style>
