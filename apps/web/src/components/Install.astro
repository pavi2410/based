---
import { findAssetInfo, lifetimeAssetDownloads, RELEASES_URL, type AllReleasesResult, type LatestRelease } from "../lib/github";
import type { InstallPlatform } from "../lib/install";
import InstallPlatformCard from "./InstallPlatformCard.astro";
import Reveal from "./Reveal.astro";

interface Props {
  release: LatestRelease | null;
  allReleases: AllReleasesResult;
  totalDownloads: number | null;
}

const { release, allReleases, totalDownloads } = Astro.props;

const version = release?.tag_name ?? null;

const macInfo      = findAssetInfo(release, /aarch64\.dmg$/i);
const linuxDebInfo = findAssetInfo(release, /\.deb$/i);
const linuxAppInfo = findAssetInfo(release, /\.AppImage$/i);
const windowsInfo  = findAssetInfo(release, /x64-setup\.exe$/i, /\.exe$/i);

const platforms: InstallPlatform[] = [
  {
    os:      "mac",
    name:    "macOS",
    detail:  "Apple Silicon",
    primary: {
      label:     ".dmg installer",
      url:       macInfo?.url ?? RELEASES_URL,
      digest:    macInfo?.digest,
      downloads: lifetimeAssetDownloads(allReleases, /aarch64\.dmg$/i),
    },
    packageManager: {
      label: "Or with Homebrew",
      command: "brew tap pavi2410/tap && brew install --cask based",
    },
  },
  {
    os:      "linux",
    name:    "Linux",
    detail:  "x86-64",
    primary: {
      label:     ".deb (Debian / Ubuntu)",
      url:       linuxDebInfo?.url ?? RELEASES_URL,
      digest:    linuxDebInfo?.digest,
      downloads: lifetimeAssetDownloads(allReleases, /\.deb$/i),
    },
    secondary: linuxAppInfo
      ? {
          label:     ".AppImage (universal)",
          url:       linuxAppInfo.url,
          digest:    linuxAppInfo.digest,
          downloads: lifetimeAssetDownloads(allReleases, /\.AppImage$/i),
        }
      : null,
  },
  {
    os:      "windows",
    name:    "Windows",
    detail:  "x86-64 · Windows 10 & 11",
    primary: {
      label:     ".exe installer",
      url:       windowsInfo?.url ?? RELEASES_URL,
      digest:    windowsInfo?.digest,
      downloads: lifetimeAssetDownloads(allReleases, /x64-setup\.exe$/i, /\.exe$/i),
    },
    packageManager: {
      label: "Or with winget",
      command: "winget install pavi2410.Based",
    },
  },
];
---

<section class="section install" id="install">
  <div class="section-head">
    <span class="eyebrow">Install</span>
    <h2 class="section-title">
      Download based{version && <span class="install-version mono">&thinsp;{version}</span>}.
    </h2>
    <p class="section-lead">
      Grab the latest stable release for your platform. Free and open source —
      no sign-up required.
    </p>
  </div>

  <div class="install-grid">
    {platforms.map((platform, i) => (
      <Reveal delay={i % 3}>
        <InstallPlatformCard {...platform} />
      </Reveal>
    ))}
  </div>

  {import.meta.env.DEV && totalDownloads !== null && (
    <p class="install-stat">
      <strong>{totalDownloads === -1 ? "?" : totalDownloads.toLocaleString()}</strong>
      total downloads across all releases
    </p>
  )}

  <Reveal class="install-note-wrap">
    <ul class="install-note">
      <li>macOS builds are <strong>ad-hoc signed</strong> (not Apple Developer ID). First launch may show an unverified-developer prompt — right-click the app and choose <span class="mono">Open</span>, or use <span class="mono">System Settings → Privacy &amp; Security → Open Anyway</span>.</li>
      <li>On Windows, choose <span class="mono">More info → Run anyway</span>.</li>
      <li>Compare your download with the SHA-256 beneath each installer (hover for the full hash).</li>
      <li><a href={RELEASES_URL} target="_blank" rel="noopener noreferrer" class="releases-link">Browse all releases →</a></li>
    </ul>
  </Reveal>
</section>

<script>
  const ua = (navigator.userAgent + " " + (navigator.platform ?? "")).toLowerCase();
  let os: string | null = null;
  if (ua.includes("mac")) os = "mac";
  else if (ua.includes("win")) os = "windows";
  else if (ua.includes("linux")) os = "linux";

  if (os) {
    document.querySelector(`.install-card[data-os="${os}"]`)?.classList.add("is-detected");
  }
</script>

<style>
  .install-version {
    font-size: 0.7em;
    font-weight: 500;
    color: var(--muted);
    letter-spacing: 0.02em;
    vertical-align: middle;
  }

  .install-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1rem;
  }

  :global(.install-note-wrap) {
    margin-top: 1.5rem;
  }

  .install-note {
    margin: 0;
    max-width: 70ch;
    color: var(--muted);
    font-size: 0.88rem;
    line-height: 1.6;
    padding-left: 1.2em;
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .install-note strong {
    color: var(--text);
    font-weight: 600;
  }

  .releases-link {
    margin-left: 0.25rem;
    color: var(--accent-blue);
    text-decoration: underline;
    text-underline-offset: 3px;
    text-decoration-color: color-mix(in srgb, var(--accent-blue) 40%, transparent);
  }

  .releases-link:hover {
    color: var(--text);
  }

  .install-stat {
    margin: 1.25rem 0 0;
    font-size: 0.88rem;
    color: var(--muted);
  }

  .install-stat strong {
    color: var(--text);
    font-weight: 600;
  }

  @media (max-width: 860px) {
    .install-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
