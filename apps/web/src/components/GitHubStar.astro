---
import { REPO_URL } from "../lib/github";
import StarIcon from "./icons/StarIcon.astro";

interface Props {
  stars: number | null;
}

const { stars } = Astro.props;
---

<a
  href={REPO_URL}
  class="star-button intro intro-delay-3"
  target="_blank"
  rel="noopener noreferrer"
>
  <StarIcon size={18} class="star-icon" />
  <span>Star on GitHub</span>
  {
    stars !== null && (
      <span class="star-count" aria-label={`${stars.toLocaleString()} stars`}>
        {stars.toLocaleString()}
      </span>
    )
  }
</a>

<style>
  .star-button {
    display: inline-flex;
    align-items: center;
    gap: 0.55rem;
    padding: 0.65rem 1rem;
    border: 1px solid var(--border);
    border-radius: 999px;
    background: var(--accent);
    color: var(--accent-fg);
    font-size: 0.925rem;
    font-weight: 500;
    line-height: 1;
    white-space: nowrap;
    transition:
      transform 120ms var(--motion-ease),
      filter 120ms var(--motion-ease),
      box-shadow 120ms var(--motion-ease);
    box-shadow: 0 0 0 0 color-mix(in srgb, var(--pg) 0%, transparent);
  }

  .star-button:hover {
    color: var(--accent-fg);
    transform: scale(1.02);
    filter: brightness(1.04);
    box-shadow: 0 8px 32px color-mix(in srgb, var(--pg) 22%, transparent);
  }

  .star-icon {
    flex-shrink: 0;
  }

  .star-count {
    padding-left: 0.55rem;
    border-left: 1px solid color-mix(in srgb, var(--accent-fg) 18%, transparent);
    color: color-mix(in srgb, var(--accent-fg) 72%, transparent);
    font-variant-numeric: tabular-nums;
  }
</style>
