---
import { findAssetInfo, lifetimeAssetDownloads, RELEASES_URL, type AllReleasesResult, type LatestRelease } from "../lib/github";
import AppleIcon from "./icons/AppleIcon.astro";
import DownloadIcon from "./icons/DownloadIcon.astro";
import LinuxIcon from "./icons/LinuxIcon.astro";
import WindowsIcon from "./icons/WindowsIcon.astro";
import Reveal from "./Reveal.astro";

interface Props {
  release: LatestRelease | null;
  allReleases: AllReleasesResult;
  totalDownloads: number | null;
}

const { release, allReleases, totalDownloads } = Astro.props;

const version = release?.tag_name ?? null;

const macInfo      = findAssetInfo(release, /aarch64\.dmg$/i);
const linuxDebInfo = findAssetInfo(release, /\.deb$/i);
const linuxAppInfo = findAssetInfo(release, /\.AppImage$/i);
const windowsInfo  = findAssetInfo(release, /x64-setup\.exe$/i, /\.exe$/i);

const platforms = [
  {
    os:        "mac",
    name:      "macOS",
    detail:    "Apple Silicon",
    primary:   { label: ".dmg installer",        url: macInfo?.url      ?? RELEASES_URL, downloads: lifetimeAssetDownloads(allReleases, /aarch64\.dmg$/i) },
    secondary: null,
  },
  {
    os:        "linux",
    name:      "Linux",
    detail:    "x86-64",
    primary:   { label: ".deb (Debian / Ubuntu)", url: linuxDebInfo?.url ?? RELEASES_URL, downloads: lifetimeAssetDownloads(allReleases, /\.deb$/i) },
    secondary: linuxAppInfo
      ? { label: ".AppImage (universal)", url: linuxAppInfo.url, downloads: lifetimeAssetDownloads(allReleases, /\.AppImage$/i) }
      : null,
  },
  {
    os:        "windows",
    name:      "Windows",
    detail:    "x86-64 · Windows 10 & 11",
    primary:   { label: ".exe installer",          url: windowsInfo?.url  ?? RELEASES_URL, downloads: lifetimeAssetDownloads(allReleases, /x64-setup\.exe$/i, /\.exe$/i) },
    secondary: null,
  },
];
---

<section class="section install" id="install">
  <div class="section-head">
    <span class="eyebrow">Install</span>
    <h2 class="section-title">
      Download based{version && <span class="install-version mono">&thinsp;{version}</span>}.
    </h2>
    <p class="section-lead">
      Grab the latest stable release for your platform. Free and open source —
      no sign-up required.
    </p>
  </div>

  <div class="install-grid">
    {platforms.map((platform, i) => (
      <Reveal delay={i % 3}>
        <div class="card install-card" data-os={platform.os}>
          <span class="install-rec mono">Detected</span>

          <span class="install-icon">
            {platform.os === "mac"     && <AppleIcon   size={20} />}
            {platform.os === "linux"   && <LinuxIcon   size={20} />}
            {platform.os === "windows" && <WindowsIcon size={20} />}
          </span>

          <h3 class="card-title">{platform.name}</h3>
          <p class="install-detail">{platform.detail}</p>

          <div class="install-links">
            <a
              href={platform.primary.url}
              class="install-dl-link"
              download
              target="_blank"
              rel="noopener noreferrer"
            >
              <DownloadIcon size={13} />
              {platform.primary.label}
              {import.meta.env.DEV && <span class="asset-dl-count">{platform.primary.downloads === -1 ? "?" : platform.primary.downloads} ↓</span>}
            </a>
            {platform.secondary && (
              <a
                href={platform.secondary.url}
                class="install-dl-link install-dl-link--secondary"
                download
                target="_blank"
                rel="noopener noreferrer"
              >
                <DownloadIcon size={13} />
                {platform.secondary.label}
                {import.meta.env.DEV && <span class="asset-dl-count">{platform.secondary.downloads === -1 ? "?" : platform.secondary.downloads} ↓</span>}
              </a>
            )}
          </div>
        </div>
      </Reveal>
    ))}
  </div>

  {import.meta.env.DEV && totalDownloads !== null && (
    <p class="install-stat">
      <strong>{totalDownloads === -1 ? "?" : totalDownloads.toLocaleString()}</strong>
      total downloads across all releases
    </p>
  )}

  <Reveal class="install-note-wrap">
    <ul class="install-note">
      <li>Installers are currently <strong>unsigned</strong>.</li>
      <li>On macOS, open <span class="mono">System Settings → Privacy &amp; Security → Open Anyway</span>.</li>
      <li>On Windows, choose <span class="mono">More info → Run anyway</span>.</li>
      <li>Each release ships a <span class="mono">checksums.txt</span> with SHA-256 hashes.</li>
      <li><a href={RELEASES_URL} target="_blank" rel="noopener noreferrer" class="releases-link">Browse all releases →</a></li>
    </ul>
  </Reveal>
</section>

<script>
  const ua = (navigator.userAgent + " " + (navigator.platform ?? "")).toLowerCase();
  let os: string | null = null;
  if (ua.includes("mac")) os = "mac";
  else if (ua.includes("win")) os = "windows";
  else if (ua.includes("linux")) os = "linux";

  if (os) {
    document.querySelector(`.install-card[data-os="${os}"]`)?.classList.add("is-detected");
  }
</script>

<style>
  .install-version {
    font-size: 0.7em;
    font-weight: 500;
    color: var(--muted);
    letter-spacing: 0.02em;
    vertical-align: middle;
  }

  .install-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1rem;
  }

  .install-card {
    position: relative;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 0;
  }

  .install-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2.75rem;
    height: 2.75rem;
    border-radius: 10px;
    background: color-mix(in srgb, var(--text) 10%, transparent);
    border: 1px solid color-mix(in srgb, var(--text) 14%, transparent);
    margin-bottom: 1rem;
    color: var(--text);
  }

  .install-detail {
    margin: 0.3rem 0 0;
    color: var(--muted);
    font-size: 0.88rem;
  }

  .install-links {
    margin-top: 1.1rem;
    display: flex;
    flex-direction: column;
    gap: 0.45rem;
    width: 100%;
  }

  .install-dl-link {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-size: 0.85rem;
    font-family: var(--font-mono);
    color: var(--accent-blue);
    transition: color 120ms var(--motion-ease), gap 120ms var(--motion-ease);
  }

  .install-dl-link:hover {
    color: var(--text);
    gap: 0.6rem;
  }

  .install-dl-link--secondary {
    color: var(--muted);
    font-size: 0.8rem;
  }

  .install-dl-link--secondary:hover {
    color: var(--text);
  }

  .asset-dl-count {
    margin-left: auto;
    font-size: 0.68rem;
    font-family: var(--font-mono);
    color: var(--muted);
    opacity: 0.55;
    white-space: nowrap;
  }

  .install-rec {
    position: absolute;
    top: 1rem;
    right: 1rem;
    display: none;
    padding: 0.15rem 0.5rem;
    border-radius: 999px;
    font-size: 0.68rem;
    letter-spacing: 0.04em;
    color: var(--mongo);
    background: color-mix(in srgb, var(--mongo) 14%, transparent);
  }

  .install-card.is-detected {
    border-color: color-mix(in srgb, var(--mongo) 45%, var(--border));
    box-shadow: 0 0 0 1px color-mix(in srgb, var(--mongo) 20%, transparent);
  }

  .install-card.is-detected .install-rec {
    display: inline-block;
  }

  :global(.install-note-wrap) {
    margin-top: 1.5rem;
  }

  .install-note {
    margin: 0;
    max-width: 70ch;
    color: var(--muted);
    font-size: 0.88rem;
    line-height: 1.6;
    padding-left: 1.2em;
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .install-note strong {
    color: var(--text);
    font-weight: 600;
  }

  .releases-link {
    margin-left: 0.25rem;
    color: var(--accent-blue);
    text-decoration: underline;
    text-underline-offset: 3px;
    text-decoration-color: color-mix(in srgb, var(--accent-blue) 40%, transparent);
  }

  .releases-link:hover {
    color: var(--text);
  }

  .install-stat {
    margin: 1.25rem 0 0;
    font-size: 0.88rem;
    color: var(--muted);
  }

  .install-stat strong {
    color: var(--text);
    font-weight: 600;
  }

  @media (max-width: 860px) {
    .install-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
